{
  "version": 2,
  "functions": {
    "api/telegram.js": { "runtime": "nodejs20.x" },
    "api/deploy.js": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/deploy", "dest": "/api/deploy.js" },
    { "src": "/api/telegram", "dest": "/api/telegram.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
